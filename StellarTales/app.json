{
  "expo": {
    "name": "StellarTales",
    "slug": "StellarTales",
    "scheme": "stellartales",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stellartales.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "StellarTales uses your location to show which stars and constellations are visible in your sky tonight.",
        "NSMicrophoneUsageDescription": "StellarTales uses the microphone to record your voice for personalized story narration.",
        "NSCameraUsageDescription": "StellarTales uses the camera to overlay star and constellation guides on your live sky view."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080B1A"
      },
      "package": "com.stellartales.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO",
        "CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-asset",
      "expo-audio",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "assets": [
      "./assets/stellartales.db"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08f33f2d-d510-4e1b-b461-24027614bfb2"
      }
    },
    "owner": "kottugumada"
  }
}
